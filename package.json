{
	"name": "showdown-vgc-team-sheet-extension",
	"description": "An extension to export team to a VGC sheet on Pokémon Showdown.",
	"version": "0.6.0",
	"author": "Kasper Wissendorf",
	"license": "MIT",
	"main": "src/background.ts",
	"scripts": {
		"build": "webpack",
		"watch": "webpack --watch",
		"start": "webpack serve",
		"format": "prettier --write .",
		"build:all": "npm run package:all",
		"build:chrome": "npm run package:chrome",
		"build:firefox": "npm run package:firefox",
		"package:chrome": "node scripts/package-extension.mjs chrome",
		"package:firefox": "node scripts/package-extension.mjs firefox",
		"package:all": "node scripts/package-extension.mjs all",
		"release:prepare": "node scripts/prepare-release.mjs"
	},
	"keywords": [
		"browser",
		"extension",
		"typescript"
	],
	"devDependencies": {
		"@types/chrome": "^0.1.40",
		"copy-webpack-plugin": "^13.0.1",
		"prettier": "3.6.2",
		"ts-loader": "^8.0.0",
		"typescript": "^4.0.0",
		"webpack": "^5.102.1",
		"webpack-cli": "^5.1.4",
		"webpack-dev-server": "^5.2.3"
	},
	"dependencies": {
		"pdf-lib": "^1.17.1"
	}
}
